# This file documents all environment variables used in the project
# For local development, create a .env.local file with these variables

# Next.js public environment variables (accessible in browser)
NEXT_PUBLIC_APP_NAME=بطل القرارات الصحيحة
NEXT_PUBLIC_APP_DESCRIPTION=حملة توعوية من جمعية حماية الأسرة والطفولة

# Analytics (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
